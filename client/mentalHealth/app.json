{
  "expo": {
    "name": "Mental Health Fitness",
    "slug": "mental-health-fitness",
    "scheme": "mentalhealth",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#faf8f3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mentalhealthfitness.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#faf8f3"
      },
      "package": "com.mentalhealthfitness.app"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
